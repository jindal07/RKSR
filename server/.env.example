# ─── RamKishan Siyaram — server environment ─────────────────────────────────
# Copy to `.env` for local development:  cp .env.example .env
# For Vercel deployment, set these in the Vercel dashboard instead.

# ── Core ─────────────────────────────────────────────────────────────────────
# Port the Express API listens on (local dev; ignored on Vercel serverless)
PORT=5000

# Frontend origin allowed by CORS.
# Local: the Vite dev server. Production: your deployed URL.
CLIENT_URL=http://localhost:5173

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# Local dev: the embedded Postgres started by `npm run db` (port 5433).
# Production (Vercel + Neon): use Neon's POOLED connection string here;
# use the DIRECT string only when running `prisma migrate deploy` / seed.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/rks

# ── Auth (JWT) ───────────────────────────────────────────────────────────────
# Use long random values in production. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# Token lifetimes (vercel/ms format: 15m, 7d, …)
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# ── Payments — Razorpay (optional) ───────────────────────────────────────────
# Leave empty to run with Cash on Delivery only; the "Pay online" option
# appears automatically once the key pair is set.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Secret configured on the Razorpay dashboard for the webhook pointing at
# https://<your-domain>/api/payment/webhook
RAZORPAY_WEBHOOK_SECRET=

# ── Image storage — Vercel Blob (production only) ────────────────────────────
# Injected automatically when a Blob store is connected to the Vercel project.
# When set, admin image uploads and seed images go to Blob instead of ./uploads.
# Leave empty for local dev (files are stored in server/uploads).
BLOB_READ_WRITE_TOKEN=

# ── Runtime ──────────────────────────────────────────────────────────────────
# Set to "production" in deployment (Vercel sets this automatically).
# Enables secure (HTTPS-only) refresh cookies.
# NODE_ENV=production
